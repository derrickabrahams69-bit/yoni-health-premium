<section
  class="yh-hero yh-hero--desktop-image-{{ section.settings.desktop_image_position }} yh-hero--mobile-image-{{ section.settings.mobile_image_position }}"
  style="
    --yh-hero-height: {{ section.settings.hero_height }};
    --yh-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  {% if section.settings.hero_image != blank %}
    <picture class="yh-hero__picture">
      {% if section.settings.mobile_hero_image != blank %}
        <source
          media="(max-width: 749px)"
          srcset="{{ section.settings.mobile_hero_image | image_url: width: 900 }}"
        >
      {% endif %}

      {{
        section.settings.hero_image
        | image_url: width: 2400
        | image_tag:
          class: 'yh-hero__image',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 2000, 2400',
          sizes: '100vw'
      }}
    </picture>
  {% endif %}

  <div class="yh-hero__overlay yh-hero__overlay--{{ section.settings.overlay_style }}"></div>

  <div class="page-width yh-hero__inner">
    <div class="yh-hero__content yh-hero__content--{{ section.settings.content_alignment }} yh-hero__content--width-{{ section.settings.content_width }}">

      {% if section.settings.eyebrow != blank %}
        <span class="yh-hero__eyebrow">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="yh-hero__heading">
          {{ section.settings.heading }}
        </h1>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="yh-hero__subheading">
          {{ section.settings.subheading }}
        </p>
      {% endif %}

      <div class="yh-hero__buttons">
        {% if section.settings.button_label != blank %}
          <a
            href="{{ section.settings.button_link | default: routes.all_products_collection_url }}"
            class="sd-button"
          >
            {{ section.settings.button_label }}
          </a>
        {% endif %}

        {% if section.settings.secondary_button != blank %}
          <a
            href="{{ section.settings.secondary_button_link | default: routes.root_url }}"
            class="sd-button sd-button--secondary"
          >
            {{ section.settings.secondary_button }}
          </a>
        {% endif %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Yoni Health Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Desktop Hero Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_hero_image",
      "label": "Mobile Hero Image"
    },
{
  "type": "select",
  "id": "desktop_image_position",
  "label": "Desktop Image Position",
  "default": "center",
  "options": [
    {
      "value": "left",
      "label": "Left"
    },
    {
      "value": "center",
      "label": "Center"
    },
    {
      "value": "right",
      "label": "Right"
    }
  ]
},
{
  "type": "select",
  "id": "mobile_image_position",
  "label": "Mobile Image Position",
  "default": "center",
  "options": [
    {
      "value": "left",
      "label": "Left"
    },
    {
      "value": "center",
      "label": "Center"
    },
    {
      "value": "right",
      "label": "Right"
    }
  ]
},
{
  "type": "text",
  "id": "eyebrow",
  "label": "Eyebrow Text",
  "default": "PREMIUM NATURAL WELLNESS"
},
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Natural Feminine Wellness"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Support your wellness journey with trusted natural products."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
{
  "type": "text",
  "id": "secondary_button",
  "label": "Secondary Button",
  "default": "Learn More"
},
{
  "type": "url",
  "id": "secondary_button_link",
  "label": "Secondary Button Link"
},
{
  "type": "range",
  "id": "overlay_opacity",
  "label": "Overlay Opacity",
  "min": 0,
  "max": 90,
  "step": 5,
  "unit": "%",
  "default": 45
},
{
  "type": "select",
  "id": "overlay_style",
  "label": "Overlay Style",
  "default": "solid",
  "options": [
    {
      "value": "solid",
      "label": "Solid"
    },
    {
      "value": "gradient-left",
      "label": "Gradient Left"
    },
    {
      "value": "gradient-right",
      "label": "Gradient Right"
    }
  ]
},
{
  "type": "select",
  "id": "hero_height",
  "label": "Hero Height",
  "default": "90vh",
  "options": [
    {
      "value": "70vh",
      "label": "Small"
    },
    {
      "value": "90vh",
      "label": "Medium"
    },
    {
      "value": "100vh",
      "label": "Full Screen"
    }
  ]
},
{
  "type": "select",
  "id": "content_alignment",
  "label": "Horizontal Content Position",
  "default": "left",
  "options": [
    {
      "value": "left",
      "label": "Left"
    },
    {
      "value": "center",
      "label": "Center"
    },
    {
      "value": "right",
      "label": "Right"
    }
  ]
},
{
  "type": "select",
  "id": "content_width",
  "label": "Content Width",
  "default": "medium",
  "options": [
    {
      "value": "narrow",
      "label": "Narrow"
    },
    {
      "value": "medium",
      "label": "Medium"
    },
    {
      "value": "wide",
      "label": "Wide"
    }
  ]
}
  ],
  "presets": [
    {
      "name": "Yoni Health Hero"
    }
  ]
}
{% endschema %}